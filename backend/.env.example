# ============================================================================
#  Option Chain Dashboard — backend configuration
#  Copy to `.env` and fill in. All values have safe defaults except Kite creds.
# ============================================================================

# --- Data provider selection -------------------------------------------------
# "kite"  = Kite Connect real-time primary, NSE fallback
# "nse"   = NSE public data only (use until you buy Kite Connect)
# "auto"  = use Kite if credentials present, else NSE
DATA_PROVIDER=auto

# --- Kite Connect (https://kite.trade) --------------------------------------
# Leave blank until you subscribe. When blank, the app runs on NSE fallback.
# No auth bypass is used — Kite stays dormant without these.
KITE_API_KEY=
KITE_API_SECRET=
# For automated daily access-token login (headless). Optional but recommended.
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=          # base32 secret from Zerodha 2FA "external TOTP" setup
# Access token is cached here after login (valid until ~6am next day).
KITE_TOKEN_CACHE=.kite_token.json

# --- Underlyings to track ----------------------------------------------------
# Comma-separated. Indices + equity F&O symbols (Kite tradingsymbol roots).
UNDERLYINGS=NIFTY,BANKNIFTY
# Strikes to keep around ATM per underlying (window = ATM ± N*step).
STRIKE_WINDOW=20

# --- Analytics parameters (match / improve the workbook) ---------------------
RISK_FREE_RATE=0.065       # r  (INDEX sheet C25 equivalent), annualized
DIVIDEND_YIELD=0.012       # q  (INDEX sheet H7 equivalent), annualized
IV_BUY_SELL_THRESHOLD=20   # Greeks!K36: avg ATM IV < thr => OPTION BUY, > => SELL
RECOMPUTE_DEBOUNCE_MS=750  # debounced metric recompute cadence

# --- Snapshot cadences (seconds) — replaces VBA RECORD* macros ---------------
SNAPSHOT_FAST_SEC=180      # 3 min
SNAPSHOT_MED_SEC=300       # 5 min
SNAPSHOT_SLOW_SEC=900      # 15 min

# --- Storage -----------------------------------------------------------------
DB_PATH=data/optionchain.db

# --- Server ------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
